{"id": "501b4fcc90bb_0000", "doc_id": "501b4fcc90bb", "source": "thuocbietduoc", "text": "* Xylocaine jelly được chỉ định để gây tê bề mặt và bôi trơn: - Niệu đạo nam giới và nữ giới trong soi bàng quang, đặt catheter, thăm dò bằng ống thông và các thủ thuật khác ở niệu đạo. - Khoang mũi và họng trong các thủ thuật nội soi như soi dạ dày và soi phế quản. - Trong soi hậu môn và trực tràng. - Đặt nội khí quản. * Điều trị triệu chứng đau do viêm bàng quang và viêm niệu đạo.", "llm_entities": [{"start": 2, "end": 17, "type": "DRUG_NAME", "text": "Xylocaine jelly"}, {"start": 352, "end": 384, "type": "CONDITION", "text": "viêm bàng quang và viêm niệu đạo"}], "entities": [{"start": 64, "end": 72, "type": "BODY_PART", "text": "Niệu đạo"}], "reviewed": true, "notes": "", "reviewed_at": "2026-06-13T16:55:19.205258+00:00"}
{"id": "501b4fcc90bb_0001", "doc_id": "501b4fcc90bb", "source": "thuocbietduoc", "text": "Giảm đau sau khi cắt bao quy đầu ở trẻ em.", "llm_entities": [{"start": 0, "end": 32, "type": "TREATMENT", "text": "Giảm đau sau khi cắt bao quy đầu"}, {"start": 21, "end": 32, "type": "BODY_PART", "text": "bao quy đầu"}], "entities": [], "reviewed": true, "notes": "", "reviewed_at": "2026-06-13T17:12:36.456291+00:00"}
