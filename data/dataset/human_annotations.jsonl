{"id": "866d2435eeef_0000", "doc_id": "866d2435eeef", "source": "thuocbietduoc", "text": "Tụt huyết áp hay bị sốc với cung lượng tim bình thường hoặc cao: NA được chỉ định như một thuốc phụ để điều trị huyết áp thấp vẫn kéo dài trong sốc sau khi đã được bồi phụ dịch đầy đủ.", "llm_entities": [{"start": 4, "end": 12, "type": "BODY_PART", "text": "huyết áp"}, {"start": 65, "end": 67, "type": "DRUG_NAME", "text": "NA"}], "entities": [], "reviewed": true, "notes": "", "reviewed_at": "2026-06-13T17:12:39.297530+00:00"}
{"id": "866d2435eeef_0001", "doc_id": "866d2435eeef", "source": "thuocbietduoc", "text": "Kéo dài tác dụng gây tê: Có thể dùng NA, nhưng trong mục đích này, adrenalin được ưa dùng hơn.", "llm_entities": [{"end": 39, "start": 37, "text": "NA", "type": "DRUG"}, {"end": 76, "start": 67, "text": "adrenalin", "type": "DRUG"}], "llm_model": "qwen2.5:7b", "entities": [{"end": 39, "start": 37, "text": "NA", "type": "DRUG"}, {"end": 76, "start": 67, "text": "adrenalin", "type": "DRUG"}], "reviewed": true, "notes": ""}
{"id": "866d2435eeef_0002", "doc_id": "866d2435eeef", "source": "thuocbietduoc", "text": "Liều NA bitartrat được tính theo NA (2 mg NA bitartrat tương đương với 1 mg NA).", "llm_entities": [], "entities": [{"start": 8, "end": 17, "type": "DRUG_NAME", "text": "bitartrat"}], "reviewed": true, "notes": "", "reviewed_at": "2026-06-13T17:55:54.664037+00:00"}
{"id": "866d2435eeef_0003", "doc_id": "866d2435eeef", "source": "thuocbietduoc", "text": "NA bitartrat phải pha loãng với dung dịch glucose 5% hoặc glucose và natri clorid Ðể tiêm truyền: Lấy 4 mg NA bitrartrat (2 ml dung dịch) hòa với 48 ml dung môi khi dùng bơm tiêm tự động.", "llm_entities": [{"end": 12, "start": 0, "text": "NA bitartrat", "type": "DRUG_NAME"}, {"end": 96, "start": 85, "text": "tiêm truyền", "type": "ROUTE"}, {"end": 106, "start": 102, "text": "4 mg", "type": "DOSE_NUM"}], "llm_model": "qwen2.5:7b", "entities": [], "reviewed": true, "notes": ""}
